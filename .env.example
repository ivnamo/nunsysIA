# Application
APP_NAME=nunsysIA
APP_ENV=development
LOG_LEVEL=INFO

# Chainlit UI
# Local sin Docker: http://localhost:8000
# Docker Compose: http://backend:8000
BACKEND_API_BASE_URL=http://localhost:8000
BACKEND_API_TIMEOUT_SECONDS=120.0

# Agentic workflow
# DeepAgents es el modo principal y por defecto.
AGENT_MODE=deepagent
# Modos disponibles para desarrollo/comparativa:
# - deepagent
# - deepagent_sidecar
# - legacy_langgraph
DEEPAGENTS_MODEL=google_genai:gemini-2.5-flash
# MAX_REPLANS solo aplica al modo legacy_langgraph.
# La memoria conversacional usa una ventana fija de 5 turnos por conversation_id.

# ERP / Northwind
# No uses DATABASE_URL aqui: Chainlit la trata como DSN de su data layer asyncpg.
# El runtime actual usa SQLite en memoria con seed data/northwind_seed.sql.
# ERP_DATABASE_URL queda reservada para persistencia externa futura.
ERP_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/northwind

# Production mock API
# Local sin Docker: http://localhost:8001
# Docker Compose: http://production-api:8001
PRODUCTION_API_BASE_URL=http://localhost:8001
PRODUCTION_API_TIMEOUT_SECONDS=5.0

# ChromaDB
# Local sin Docker: persistent. Docker Compose/servidor remoto: CHROMA_MODE=http.
# Docker Compose: CHROMA_HOST=chromadb, CHROMA_PORT=8000.
CHROMA_MODE=persistent
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=documents
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=3
MAX_DOCUMENT_UPLOAD_BYTES=10485760

# LLM provider
# No versionar secretos reales.
# Local dev: puedes usar GEMINI_API_KEY/OPENAI_API_KEY en tu .env privado.
# Docker/produccion: prefiere *_API_KEY_FILE con secretos montados en /run/secrets.
# LLM_PROVIDER aplica a capas auxiliares y al flujo legacy; el flujo principal
# DeepAgents usa DEEPAGENTS_MODEL y requiere una clave compatible cuando se
# ejecutan consultas reales contra /api/query.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_KEY_FILE=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_TRANSPORT=rest
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=45

# Embeddings
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL=gemini-embedding-001
