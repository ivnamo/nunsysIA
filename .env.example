# Application
APP_NAME=nunsysIA
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Chainlit UI
BACKEND_API_BASE_URL=http://api:8000
BACKEND_API_TIMEOUT_SECONDS=30.0

# Agentic workflow
MAX_REPLANS=2
MEMORY_WINDOW=5

# ERP / Northwind
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/northwind

# Production mock API
PRODUCTION_API_BASE_URL=http://production-api:8001
PRODUCTION_API_TIMEOUT_SECONDS=5.0

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=documents
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=3
MAX_DOCUMENT_UPLOAD_BYTES=10485760

# LLM provider
# Do not commit real secrets.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=8

# Embeddings
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL=gemini-embedding-001
