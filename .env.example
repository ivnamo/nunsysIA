# Application
APP_NAME=nunsysIA
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Agentic workflow
MAX_REPLANS=2
MEMORY_WINDOW=5

# ERP / Northwind
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/northwind

# Production mock API
PRODUCTION_API_BASE_URL=http://production-api:8001

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=documents
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=3
MAX_DOCUMENT_UPLOAD_BYTES=10485760

# LLM provider
# Do not commit real secrets.
OPENAI_API_KEY=
LLM_MODEL=
EMBEDDING_MODEL=
